{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Nexus IDE: Cleanup Services",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "\"${workspaceFolder}\\src\\nexus-ide\\restart-services.ps1\""
            ],
            "options": {
                "shell": {
                    "executable": "powershell.exe",
                    "args": [
                        "-NoProfile",
                        "-Command"
                    ]
                }
            },
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        },
        {
            "label": "Nexus IDE: Compile",
            "type": "shell",
            "command": "npm run compile",
            "group": "build",
            "problemMatcher": "$tsc",
            "options": {
                "cwd": "${workspaceFolder}/src/nexus-ide"
            }
        },
        {
            "label": "Nexus IDE: Build Backends",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "\"${workspaceFolder}\\build.ps1\""
            ],
            "group": "build",
            "problemMatcher": "$msCompile",
            "options": {
                "shell": {
                    "executable": "powershell.exe",
                    "args": [
                        "-NoProfile",
                        "-Command"
                    ]
                }
            }
        },
        {
            "label": "Nexus IDE: Run Debug Gateway",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "\"${workspaceFolder}\\src\\nexus-ide\\start-debug-gateway.ps1\""
            ],
            "options": {
                "shell": {
                    "executable": "powershell.exe",
                    "args": [
                        "-NoProfile",
                        "-Command"
                    ]
                }
            },
            "isBackground": true,
            "problemMatcher": {
                "owner": "custom",
                "pattern": {
                    "regexp": "^(.*)$",
                    "message": 1
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "DEBUG_GATEWAY_STARTING",
                    "endsPattern": "DEBUG_GATEWAY_READY"
                }
            },
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        },
        {
            "label": "Nexus IDE: Prepare Debug",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Nexus IDE: Cleanup Services",
                "Nexus IDE: Build Backends",
                "Nexus IDE: Compile",
                "Nexus IDE: Run Debug Gateway"
            ]
        }
    ]
}
